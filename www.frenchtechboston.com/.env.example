# =============================================================================
# FRENCH TECH CHAPTER - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
# 1. Create a new Supabase project at https://supabase.com
# 2. Go to Settings > API
# 3. Copy the "Project URL" and "anon public" key below
# 4. Copy the "service_role" key (keep this secret!)

PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# RESEND EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
# Get your API key from: https://resend.com/api-keys
#
# 1. Create a Resend account at https://resend.com
# 2. Add and verify your email domain (e.g., mail.frenchtech-sf.com)
# 3. Create an API key with send permissions

RESEND_API_KEY=re_your-api-key-here

# -----------------------------------------------------------------------------
# FEDERATION CONFIGURATION (Optional)
# -----------------------------------------------------------------------------
# Ed25519 keypair for cross-chapter communication.
# Generate keys by running: npx ts-node scripts/generate-federation-keys.ts
#
# The public key should be added to network-registry.ts for other chapters to
# verify your signed requests. The private key must be kept secret!
#
# Required for:
# - Sharing investor directory with other chapters
# - Receiving cross-chapter intro requests
# - Sending cross-chapter intro requests

FEDERATION_PRIVATE_KEY=your-base64-private-key-here
FEDERATION_PUBLIC_KEY=your-base64-public-key-here
