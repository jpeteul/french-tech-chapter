---
import PublicLayout from '../layouts/PublicLayout.astro';
import Container from '../components/common/Container.astro';
import Section from '../components/common/Section.astro';
import Card from '../components/common/Card.astro';
import Button from '../components/common/Button.astro';
import { CONTACT_EMAIL, SOCIAL_LINKS } from '../lib/constants';
---

<PublicLayout title="Contact" description="Get in touch with La French Tech Boston.">
  <Section background="navy-gradient" padding="lg">
    <Container>
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold mb-6">Contact Us</h1>
        <p class="text-xl text-white/70">
          Have questions? Want to get involved? We'd love to hear from you.
        </p>
      </div>
    </Container>
  </Section>

  <Section background="navy-gradient" padding="lg">
    <Container size="md">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="backdrop-blur-xl bg-white/90 rounded-2xl p-8 border border-white/50 shadow-xl shadow-black/20">
          <h2 class="text-2xl font-bold text-ft-black mb-6">Send us a message</h2>
          <form id="contact-form" class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-ft-black mb-1">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ft-red focus:border-ft-red bg-white/80 text-gray-900 placeholder-gray-400"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-ft-black mb-1">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ft-red focus:border-ft-red bg-white/80 text-gray-900 placeholder-gray-400"
                placeholder="you@company.com"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-medium text-ft-black mb-1">
                Subject
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ft-red focus:border-ft-red bg-white/80 text-gray-900"
              >
                <option value="">Select a topic</option>
                <option value="membership">Membership inquiry</option>
                <option value="sponsorship">Sponsorship</option>
                <option value="events">Events</option>
                <option value="media">Media/Press</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-ft-black mb-1">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ft-red focus:border-ft-red resize-none bg-white/80 text-gray-900 placeholder-gray-400"
                placeholder="Your message..."
              ></textarea>
            </div>

            <Button type="submit" variant="primary" class="w-full">
              Send Message
            </Button>

            <p id="form-message" class="text-sm text-center hidden"></p>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">Other ways to reach us</h2>

          <div class="space-y-6">
            <Card variant="glass" hover>
              <h3 class="font-semibold text-ft-black mb-2">Email</h3>
              <a href={`mailto:${CONTACT_EMAIL}`} class="text-ft-red hover:underline">
                {CONTACT_EMAIL}
              </a>
            </Card>

            <Card variant="glass" hover>
              <h3 class="font-semibold text-ft-black mb-2">LinkedIn</h3>
              <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="text-ft-red hover:underline flex items-center gap-2">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                Follow us on LinkedIn
              </a>
            </Card>

            <Card variant="glass" hover>
              <h3 class="font-semibold text-ft-black mb-2">Location</h3>
              <p class="text-gray-600">
                Boston, Massachusetts<br />
                Cambridge Innovation Center
              </p>
            </Card>
          </div>
        </div>
      </div>
    </Container>
  </Section>
</PublicLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const message = document.getElementById('form-message') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: formData.get('name'),
          email: formData.get('email'),
          subject: formData.get('subject'),
          message: formData.get('message'),
        }),
      });

      const data = await response.json();

      if (response.ok) {
        message.textContent = 'Message sent! We\'ll get back to you soon.';
        message.className = 'text-sm text-center text-green-600';
        form.reset();
      } else {
        message.textContent = data.error || 'Something went wrong.';
        message.className = 'text-sm text-center text-red-600';
      }
      message.classList.remove('hidden');
    } catch (error) {
      message.textContent = 'Something went wrong. Please try again.';
      message.className = 'text-sm text-center text-red-600';
      message.classList.remove('hidden');
    }
  });
</script>
