---
import PublicLayout from '../../layouts/PublicLayout.astro';
import Container from '../../components/common/Container.astro';
import Section from '../../components/common/Section.astro';
import EventCard from '../../components/events/EventCard.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

export const prerender = false;

// Default fallback events
let upcomingEvents: any[] = [];
let pastEvents: any[] = [];

const now = new Date();

const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime);

if (supabaseAdmin) {
  // Fetch upcoming events
  const { data: upcoming } = await supabaseAdmin
    .from('events')
    .select('*')
    .gte('date', now.toISOString())
    .order('date', { ascending: true });

  // Fetch past events
  const { data: past } = await supabaseAdmin
    .from('events')
    .select('*')
    .lt('date', now.toISOString())
    .order('date', { ascending: false })
    .limit(10);

  if (upcoming) {
    upcomingEvents = upcoming.map(e => ({
      title: e.title,
      date: e.date,
      location: e.location,
      description: e.description || '',
      membersOnly: e.is_members_only,
      slug: e.slug,
      registrationUrl: e.registration_url,
      imageUrl: e.image_url,
    }));
  }

  if (past) {
    pastEvents = past.map(e => ({
      title: e.title,
      date: e.date,
      location: e.location,
      description: e.description || '',
      membersOnly: e.is_members_only,
      slug: e.slug,
    }));
  }
}

// Fetch gallery photos from database
let galleryPhotos: { src: string; alt: string; wide?: boolean; isFullUrl?: boolean }[] = [];
let dbPhotos: any[] | null = null;

if (supabaseAdmin) {
  const { data, error } = await supabaseAdmin
    .from('event_photos')
    .select('*')
    .order('display_order', { ascending: true });

  if (error) {
    console.error('Error fetching event photos:', error);
  }
  dbPhotos = data;
}

if (dbPhotos && dbPhotos.length > 0) {
  // Use photos from database
  galleryPhotos = dbPhotos.map(photo => ({
    src: photo.url,
    alt: photo.alt_text || 'Event photo',
    wide: photo.is_wide,
    isFullUrl: true,
  }));
} else {
  // Fallback to static photos if database is empty
  galleryPhotos = [
    { src: 'event-podium.avif', alt: 'Event presentation' },
    { src: 'event-networking-1.jpg', alt: 'Networking event' },
    { src: 'event-2.avif', alt: 'Community gathering' },
    { src: 'event-networking-2.jpeg', alt: 'Networking' },
    { src: 'event-group-1.png', alt: 'Group photo', wide: true },
    { src: 'event-4.avif', alt: 'Event moment' },
    { src: 'event-5.avif', alt: 'Event moment' },
    { src: 'event-networking-3.jpg', alt: 'Networking' },
    { src: 'event-networking-4.jpg', alt: 'Networking' },
    { src: 'event-group-2.png', alt: 'Group photo', wide: true },
  ];
}
---

<PublicLayout title="Events" description="Join La French Tech Boston events - networking, workshops, and exclusive member gatherings.">
  <!-- Hero Section with Photo Backdrop -->
  <section class="relative text-white overflow-hidden min-h-[400px] flex items-center">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
      <img
        src="/images/events/events-hero.avif"
        alt="French Tech Boston event"
        class="w-full h-full object-cover"
      />
      <!-- Dark overlay for text readability -->
      <div class="absolute inset-0 bg-gradient-to-r from-ft-navy/85 via-ft-navy/70 to-ft-navy/50"></div>
    </div>

    <!-- Decorative gradient blobs -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-br from-ft-red/20 to-transparent rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-to-tr from-ft-blue/30 to-transparent rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

    <Container class="relative py-20 sm:py-28">
      <div class="max-w-3xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 bg-ft-red/20 backdrop-blur-sm rounded-full border border-ft-red/30">
          <span class="w-2 h-2 bg-ft-red rounded-full animate-pulse"></span>
          <span class="text-sm text-ft-red font-medium">Community Events</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 drop-shadow-lg">Events</h1>
        <p class="text-xl text-gray-200 drop-shadow-md max-w-2xl">
          Connect with the community at our networking events, workshops, and exclusive member gatherings.
        </p>
      </div>
    </Container>
  </section>

  <!-- Upcoming Events -->
  <Section background="navy-gradient" padding="lg">
    <Container>
      <h2 class="text-2xl font-bold text-white mb-8">Upcoming Events</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {upcomingEvents.map((event) => (
          <EventCard {...event} />
        ))}
      </div>
    </Container>
  </Section>

  <!-- Past Events -->
  <Section background="navy-gradient" padding="lg">
    <Container>
      <h2 class="text-2xl font-bold text-white mb-8">Past Events</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {pastEvents.map((event) => (
          <EventCard {...event} />
        ))}
      </div>
    </Container>
  </Section>

  <!-- Photo Gallery -->
  <Section background="navy-gradient" padding="lg">
    <Container>
      <h2 class="text-2xl font-bold text-white mb-4">Community in Action</h2>
      <p class="text-white/70 mb-8">Highlights from our events and gatherings.</p>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {galleryPhotos.map((photo) => {
          const imgSrc = photo.isFullUrl ? photo.src : `/images/events/${photo.src}`;
          return (
            <a
              href={imgSrc}
              class={`gallery-item group relative aspect-square overflow-hidden rounded-xl ${photo.wide ? 'md:col-span-2' : ''}`}
              data-lightbox
            >
              <img
                src={imgSrc}
                alt={photo.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-ft-navy/0 group-hover:bg-ft-navy/40 transition-colors duration-300"></div>
            </a>
          );
        })}
      </div>
    </Container>
  </Section>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4">
    <button id="lightbox-close" class="absolute top-4 right-4 text-white/70 hover:text-white text-4xl">&times;</button>
    <button id="lightbox-prev" class="absolute left-4 text-white/70 hover:text-white text-4xl">&larr;</button>
    <button id="lightbox-next" class="absolute right-4 text-white/70 hover:text-white text-4xl">&rarr;</button>
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[90vh] object-contain" />
  </div>

  <script>
    const galleryItems = document.querySelectorAll('.gallery-item');
    const lightbox = document.getElementById('lightbox') as HTMLDivElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');

    let currentIndex = 0;
    const images = Array.from(galleryItems).map(item => item.getAttribute('href') || '');

    galleryItems.forEach((item, index) => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        currentIndex = index;
        showImage(currentIndex);
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
      });
    });

    function showImage(index: number) {
      lightboxImg.src = images[index];
    }

    closeBtn?.addEventListener('click', () => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
    });

    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
      }
    });

    prevBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      showImage(currentIndex);
    });

    nextBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % images.length;
      showImage(currentIndex);
    });

    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
      } else if (e.key === 'ArrowLeft') {
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        showImage(currentIndex);
      } else if (e.key === 'ArrowRight') {
        currentIndex = (currentIndex + 1) % images.length;
        showImage(currentIndex);
      }
    });
  </script>
</PublicLayout>
