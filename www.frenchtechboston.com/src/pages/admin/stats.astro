---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Card from '../../components/common/Card.astro';

export const prerender = false;
---

<AdminLayout title="Member Analytics">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white">Member Analytics</h1>
    <p class="text-white/70 mt-2">
      Activity and engagement metrics for La French Tech Boston
    </p>
  </div>

  <!-- Loading State -->
  <div id="loading" class="text-center py-12">
    <div class="inline-block w-8 h-8 border-4 border-white border-t-transparent rounded-full animate-spin"></div>
    <p class="text-white/70 mt-3">Loading analytics...</p>
  </div>

  <!-- Error State -->
  <div id="error" class="hidden">
    <Card variant="glass">
      <p class="text-red-600">Failed to load analytics. Please try again.</p>
    </Card>
  </div>

  <!-- Stats Content -->
  <div id="stats-content" class="hidden">
    <!-- Summary Stats -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <Card variant="glass" hover>
        <div class="text-center">
          <div class="text-3xl font-bold text-gray-900" id="stat-total-members">-</div>
          <div class="text-sm text-gray-500">Total Members</div>
        </div>
      </Card>
      <Card variant="glass" hover>
        <div class="text-center">
          <div class="text-3xl font-bold text-emerald-600" id="stat-active-7d">-</div>
          <div class="text-sm text-gray-500">Active (7 days)</div>
        </div>
      </Card>
      <Card variant="glass" hover>
        <div class="text-center">
          <div class="text-3xl font-bold text-blue-600" id="stat-active-30d">-</div>
          <div class="text-sm text-gray-500">Active (30 days)</div>
        </div>
      </Card>
      <Card variant="glass" hover>
        <div class="text-center">
          <div class="text-3xl font-bold text-amber-600" id="stat-engagement">-</div>
          <div class="text-sm text-gray-500">30-day Engagement</div>
        </div>
      </Card>
    </div>

    <!-- Investor Directory Stats -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <Card variant="glass" hover>
        <div class="text-center">
          <div class="text-3xl font-bold text-purple-600" id="stat-investors">-</div>
          <div class="text-sm text-gray-500">Investors</div>
        </div>
      </Card>
      <Card variant="glass" hover>
        <div class="text-center">
          <div class="text-3xl font-bold text-cyan-600" id="stat-contacts">-</div>
          <div class="text-sm text-gray-500">Total Contacts</div>
        </div>
      </Card>
      <Card variant="glass" hover>
        <div class="text-center">
          <div class="text-3xl font-bold text-pink-600" id="stat-intros">-</div>
          <div class="text-sm text-gray-500">Intro Requests</div>
        </div>
      </Card>
      <Card variant="glass" hover>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-600" id="stat-accept-rate">-</div>
          <div class="text-sm text-gray-500">Accept Rate</div>
        </div>
      </Card>
    </div>

    <div class="grid lg:grid-cols-2 gap-6 mb-8">
      <!-- Recent Activity -->
      <Card variant="glass" hover>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Activity</h2>
        <div id="recent-activity" class="space-y-3">
          <!-- Populated by JS -->
        </div>
      </Card>

      <!-- Most Active Members -->
      <Card variant="glass" hover>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Most Active Members</h2>
        <div id="most-active" class="space-y-3">
          <!-- Populated by JS -->
        </div>
      </Card>
    </div>

    <div class="grid lg:grid-cols-2 gap-6">
      <!-- Top Contributors (Investors Added) -->
      <Card variant="glass" hover>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Top Investor Contributors</h2>
        <div id="top-contributors" class="space-y-3">
          <!-- Populated by JS -->
        </div>
      </Card>

      <!-- Top Requesters (Intros Requested) -->
      <Card variant="glass" hover>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Most Intro Requests</h2>
        <div id="top-requesters" class="space-y-3">
          <!-- Populated by JS -->
        </div>
      </Card>
    </div>
  </div>
</AdminLayout>

<script>
  async function loadStats() {
    const loading = document.getElementById('loading');
    const error = document.getElementById('error');
    const content = document.getElementById('stats-content');

    try {
      const res = await fetch('/api/admin/stats');
      if (!res.ok) throw new Error('Failed to fetch');

      const data = await res.json();

      // Update summary stats
      document.getElementById('stat-total-members')!.textContent = data.summary.totalMembers.toString();
      document.getElementById('stat-active-7d')!.textContent = data.summary.active7d.toString();
      document.getElementById('stat-active-30d')!.textContent = data.summary.active30d.toString();

      const engagement = data.summary.totalMembers > 0
        ? Math.round((data.summary.active30d / data.summary.totalMembers) * 100)
        : 0;
      document.getElementById('stat-engagement')!.textContent = `${engagement}%`;

      // Update investor stats
      document.getElementById('stat-investors')!.textContent = data.summary.totalInvestors.toString();
      document.getElementById('stat-contacts')!.textContent = data.summary.totalContacts.toString();
      document.getElementById('stat-intros')!.textContent = data.summary.totalIntroRequests.toString();
      document.getElementById('stat-accept-rate')!.textContent = `${data.summary.introAcceptRate}%`;

      // Render recent activity
      const recentEl = document.getElementById('recent-activity')!;
      if (data.recentActivity.length === 0) {
        recentEl.innerHTML = '<p class="text-gray-400 text-sm">No recent activity yet. Activity will appear here once members start logging in.</p>';
      } else {
        recentEl.innerHTML = data.recentActivity.map((m: any) => `
          <div class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
            <div>
              <div class="font-medium text-gray-900">${escapeHtml(m.name)}</div>
              <div class="text-sm text-gray-500">${escapeHtml(m.company || '')}</div>
            </div>
            <div class="text-sm text-gray-400">${formatRelativeTime(m.last_seen_at)}</div>
          </div>
        `).join('');
      }

      // Render most active members
      const activeEl = document.getElementById('most-active')!;
      if (data.mostActiveMembers.length === 0) {
        activeEl.innerHTML = '<p class="text-gray-400 text-sm">No login data yet. Members will appear here after they log in.</p>';
      } else {
        activeEl.innerHTML = data.mostActiveMembers.map((m: any, i: number) => `
          <div class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
            <div class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full bg-blue-100 text-blue-600 text-xs flex items-center justify-center font-medium">${i + 1}</span>
              <div>
                <div class="font-medium text-gray-900">${escapeHtml(m.name)}</div>
                <div class="text-sm text-gray-500">${escapeHtml(m.company || '')}</div>
              </div>
            </div>
            <div class="text-sm text-blue-600 font-medium">${m.login_count} logins</div>
          </div>
        `).join('');
      }

      // Render top contributors
      const contribEl = document.getElementById('top-contributors')!;
      if (data.topContributors.length === 0) {
        contribEl.innerHTML = '<p class="text-gray-400 text-sm">No contributors yet. Members who add investors will appear here.</p>';
      } else {
        contribEl.innerHTML = data.topContributors.map((m: any, i: number) => `
          <div class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
            <div class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full bg-purple-100 text-purple-600 text-xs flex items-center justify-center font-medium">${i + 1}</span>
              <div>
                <div class="font-medium text-gray-900">${escapeHtml(m.name)}</div>
                <div class="text-sm text-gray-500">${escapeHtml(m.company || '')}</div>
              </div>
            </div>
            <div class="text-sm text-purple-600 font-medium">${m.count} investors</div>
          </div>
        `).join('');
      }

      // Render top requesters
      const reqEl = document.getElementById('top-requesters')!;
      if (data.topRequesters.length === 0) {
        reqEl.innerHTML = '<p class="text-gray-400 text-sm">No intro requests yet. Members who request intros will appear here.</p>';
      } else {
        reqEl.innerHTML = data.topRequesters.map((m: any, i: number) => `
          <div class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
            <div class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full bg-pink-100 text-pink-600 text-xs flex items-center justify-center font-medium">${i + 1}</span>
              <div>
                <div class="font-medium text-gray-900">${escapeHtml(m.name)}</div>
                <div class="text-sm text-gray-500">${escapeHtml(m.company || '')}</div>
              </div>
            </div>
            <div class="text-sm text-pink-600 font-medium">${m.count} requests</div>
          </div>
        `).join('');
      }

      // Show content
      loading!.classList.add('hidden');
      content!.classList.remove('hidden');

    } catch (err) {
      console.error('Failed to load stats:', err);
      loading!.classList.add('hidden');
      error!.classList.remove('hidden');
    }
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function formatRelativeTime(dateStr: string): string {
    if (!dateStr) return 'Never';
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return `${diffMins}m ago`;
    if (diffHours < 24) return `${diffHours}h ago`;
    if (diffDays < 7) return `${diffDays}d ago`;
    return date.toLocaleDateString();
  }

  // Load on page load
  loadStats();
</script>
