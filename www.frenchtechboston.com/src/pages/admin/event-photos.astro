---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Container from '../../components/common/Container.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

export const prerender = false;

const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime);

// Fetch existing photos (AdminLayout handles authentication)
let photos: any[] = [];
if (supabaseAdmin) {
  const { data } = await supabaseAdmin
    .from('event_photos')
    .select('*')
    .order('display_order', { ascending: true });
  photos = data || [];
}
---

<AdminLayout title="Event Photos">
  <Container>
    <div class="flex justify-between items-center mb-8">
      <div>
        <h1 class="text-3xl font-bold text-white">Event Photos</h1>
        <p class="text-white/70 mt-1">Manage the photo gallery on the events page</p>
      </div>
      <button
        id="add-photo-btn"
        class="px-4 py-2 bg-ft-red text-white rounded-xl hover:bg-ft-red/90 transition-colors font-medium flex items-center gap-2"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Photo
      </button>
    </div>

    <!-- Upload Modal -->
    <div id="upload-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
      <div class="bg-white rounded-2xl p-6 max-w-md w-full">
        <h2 class="text-xl font-bold text-ft-black mb-4">Add New Photo</h2>
        <form id="upload-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Photo</label>
            <input
              type="file"
              id="photo-file"
              accept="image/*"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-ft-red/20 focus:border-ft-red"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description (Alt Text)</label>
            <input
              type="text"
              id="alt-text"
              placeholder="e.g., Networking event at CIC"
              class="w-full px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-ft-red/20 focus:border-ft-red"
            />
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="is-wide" class="rounded border-gray-300" />
            <label for="is-wide" class="text-sm text-gray-700">Wide photo (spans 2 columns)</label>
          </div>
          <div class="flex gap-3 pt-4">
            <button
              type="button"
              id="cancel-upload"
              class="flex-1 px-4 py-2 border border-gray-300 rounded-xl hover:bg-gray-50 transition-colors"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="flex-1 px-4 py-2 bg-ft-red text-white rounded-xl hover:bg-ft-red/90 transition-colors font-medium"
            >
              Upload
            </button>
          </div>
        </form>
        <div id="upload-progress" class="hidden mt-4">
          <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-ft-red transition-all duration-300" style="width: 0%"></div>
          </div>
          <p class="text-sm text-gray-600 mt-2 text-center">Uploading...</p>
        </div>
      </div>
    </div>

    <!-- Edit Modal -->
    <div id="edit-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4">
      <div class="bg-white rounded-2xl p-6 max-w-md w-full">
        <h2 class="text-xl font-bold text-ft-black mb-4">Edit Photo</h2>
        <form id="edit-form" class="space-y-4">
          <input type="hidden" id="edit-id" />
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description (Alt Text)</label>
            <input
              type="text"
              id="edit-alt-text"
              placeholder="e.g., Networking event at CIC"
              class="w-full px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-ft-red/20 focus:border-ft-red"
            />
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="edit-is-wide" class="rounded border-gray-300" />
            <label for="edit-is-wide" class="text-sm text-gray-700">Wide photo (spans 2 columns)</label>
          </div>
          <div class="flex gap-3 pt-4">
            <button
              type="button"
              id="cancel-edit"
              class="flex-1 px-4 py-2 border border-gray-300 rounded-xl hover:bg-gray-50 transition-colors"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="flex-1 px-4 py-2 bg-ft-red text-white rounded-xl hover:bg-ft-red/90 transition-colors font-medium"
            >
              Save Changes
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Photos Grid -->
    {photos && photos.length > 0 ? (
      <div class="space-y-3" id="photos-list">
        {photos.map((photo, index) => (
          <div
            class="flex items-center gap-4 backdrop-blur-xl bg-white/10 border border-white/20 rounded-xl p-3"
            data-id={photo.id}
            data-order={photo.display_order}
          >
            <!-- Thumbnail -->
            <div class={`flex-shrink-0 ${photo.is_wide ? 'w-32' : 'w-20'}`}>
              <img
                src={photo.url}
                alt={photo.alt_text || 'Event photo'}
                class="w-full aspect-square object-cover rounded-lg"
              />
            </div>

            <!-- Info -->
            <div class="flex-1 min-w-0">
              <p class="text-white font-medium truncate">{photo.alt_text || 'No description'}</p>
              <div class="flex items-center gap-2 mt-1">
                {photo.is_wide && (
                  <span class="text-xs bg-blue-500/20 text-blue-300 px-2 py-0.5 rounded">Wide</span>
                )}
                <span class="text-xs text-white/50">Position: {index + 1}</span>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-1">
              <!-- Move Up -->
              <button
                class="move-up-btn p-2 text-white/60 hover:text-white hover:bg-white/10 rounded-lg transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                data-id={photo.id}
                data-order={photo.display_order}
                disabled={index === 0}
                title="Move up"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                </svg>
              </button>

              <!-- Move Down -->
              <button
                class="move-down-btn p-2 text-white/60 hover:text-white hover:bg-white/10 rounded-lg transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                data-id={photo.id}
                data-order={photo.display_order}
                disabled={index === photos.length - 1}
                title="Move down"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>

              <!-- Edit -->
              <button
                class="edit-btn p-2 text-white/60 hover:text-white hover:bg-white/10 rounded-lg transition-colors"
                data-id={photo.id}
                data-alt={photo.alt_text || ''}
                data-wide={photo.is_wide}
                title="Edit"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              </button>

              <!-- Delete -->
              <button
                class="delete-btn p-2 text-red-400 hover:text-red-300 hover:bg-red-500/20 rounded-lg transition-colors"
                data-id={photo.id}
                title="Delete"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="backdrop-blur-xl bg-white/10 border border-white/20 rounded-2xl text-center py-12">
        <div class="text-4xl mb-4">📷</div>
        <h3 class="text-xl font-semibold text-white mb-2">No photos yet</h3>
        <p class="text-white/70 mb-4">Upload photos to display in the events gallery</p>
      </div>
    )}

    <!-- Instructions -->
    <div class="mt-8 p-4 backdrop-blur-xl bg-white/10 border border-white/20 rounded-xl">
      <h3 class="font-semibold text-white mb-2">How it works</h3>
      <ul class="text-sm text-white/80 space-y-1">
        <li>• Click "Add Photo" to upload a new image</li>
        <li>• Use the arrow buttons to reorder photos</li>
        <li>• Click the pencil icon to edit description or toggle wide mode</li>
        <li>• Wide photos span 2 columns in the gallery</li>
      </ul>
    </div>
  </Container>
</AdminLayout>

<script>
  // Upload Modal
  const uploadModal = document.getElementById('upload-modal') as HTMLDivElement;
  const addBtn = document.getElementById('add-photo-btn');
  const cancelUploadBtn = document.getElementById('cancel-upload');
  const uploadForm = document.getElementById('upload-form') as HTMLFormElement;
  const progressDiv = document.getElementById('upload-progress') as HTMLDivElement;
  const progressBar = document.getElementById('progress-bar') as HTMLDivElement;

  addBtn?.addEventListener('click', () => {
    uploadModal.classList.remove('hidden');
    uploadModal.classList.add('flex');
  });

  cancelUploadBtn?.addEventListener('click', () => {
    uploadModal.classList.add('hidden');
    uploadModal.classList.remove('flex');
    uploadForm.reset();
  });

  uploadModal?.addEventListener('click', (e) => {
    if (e.target === uploadModal) {
      uploadModal.classList.add('hidden');
      uploadModal.classList.remove('flex');
      uploadForm.reset();
    }
  });

  uploadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const fileInput = document.getElementById('photo-file') as HTMLInputElement;
    const altTextInput = document.getElementById('alt-text') as HTMLInputElement;
    const isWideInput = document.getElementById('is-wide') as HTMLInputElement;

    const file = fileInput.files?.[0];
    if (!file) return;

    uploadForm.classList.add('hidden');
    progressDiv.classList.remove('hidden');
    progressBar.style.width = '30%';

    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('alt_text', altTextInput.value);
      formData.append('is_wide', isWideInput.checked.toString());

      progressBar.style.width = '60%';

      const response = await fetch('/api/admin/event-photos', {
        method: 'POST',
        body: formData,
      });

      progressBar.style.width = '100%';

      if (response.ok) {
        window.location.reload();
      } else {
        const data = await response.json();
        alert(data.error || 'Upload failed');
        uploadForm.classList.remove('hidden');
        progressDiv.classList.add('hidden');
        progressBar.style.width = '0%';
      }
    } catch (error) {
      alert('Upload failed. Please try again.');
      uploadForm.classList.remove('hidden');
      progressDiv.classList.add('hidden');
      progressBar.style.width = '0%';
    }
  });

  // Edit Modal
  const editModal = document.getElementById('edit-modal') as HTMLDivElement;
  const editForm = document.getElementById('edit-form') as HTMLFormElement;
  const cancelEditBtn = document.getElementById('cancel-edit');
  const editIdInput = document.getElementById('edit-id') as HTMLInputElement;
  const editAltTextInput = document.getElementById('edit-alt-text') as HTMLInputElement;
  const editIsWideInput = document.getElementById('edit-is-wide') as HTMLInputElement;

  document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      editIdInput.value = el.dataset.id || '';
      editAltTextInput.value = el.dataset.alt || '';
      editIsWideInput.checked = el.dataset.wide === 'true';
      editModal.classList.remove('hidden');
      editModal.classList.add('flex');
    });
  });

  cancelEditBtn?.addEventListener('click', () => {
    editModal.classList.add('hidden');
    editModal.classList.remove('flex');
  });

  editModal?.addEventListener('click', (e) => {
    if (e.target === editModal) {
      editModal.classList.add('hidden');
      editModal.classList.remove('flex');
    }
  });

  editForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    try {
      const response = await fetch('/api/admin/event-photos', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: editIdInput.value,
          alt_text: editAltTextInput.value,
          is_wide: editIsWideInput.checked,
        }),
      });

      if (response.ok) {
        window.location.reload();
      } else {
        const data = await response.json();
        alert(data.error || 'Failed to update');
      }
    } catch (error) {
      alert('Failed to update. Please try again.');
    }
  });

  // Delete
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete this photo?')) return;

      const id = (btn as HTMLElement).dataset.id;

      try {
        const response = await fetch('/api/admin/event-photos', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });

        if (response.ok) {
          window.location.reload();
        } else {
          alert('Failed to delete photo');
        }
      } catch (error) {
        alert('Failed to delete photo');
      }
    });
  });

  // Reorder - Move Up/Down
  async function swapOrder(id1: string, order1: number, id2: string, order2: number) {
    try {
      // Update first photo
      await fetch('/api/admin/event-photos', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id1, display_order: order2 }),
      });

      // Update second photo
      await fetch('/api/admin/event-photos', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id2, display_order: order1 }),
      });

      window.location.reload();
    } catch (error) {
      alert('Failed to reorder');
    }
  }

  document.querySelectorAll('.move-up-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const row = el.closest('[data-id]') as HTMLElement;
      const prevRow = row.previousElementSibling as HTMLElement;

      if (prevRow && prevRow.dataset.id) {
        swapOrder(
          row.dataset.id!,
          parseInt(row.dataset.order || '0'),
          prevRow.dataset.id,
          parseInt(prevRow.dataset.order || '0')
        );
      }
    });
  });

  document.querySelectorAll('.move-down-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const row = el.closest('[data-id]') as HTMLElement;
      const nextRow = row.nextElementSibling as HTMLElement;

      if (nextRow && nextRow.dataset.id) {
        swapOrder(
          row.dataset.id!,
          parseInt(row.dataset.order || '0'),
          nextRow.dataset.id,
          parseInt(nextRow.dataset.order || '0')
        );
      }
    });
  });
</script>
