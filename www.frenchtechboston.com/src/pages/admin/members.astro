---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Card from '../../components/common/Card.astro';
import Badge from '../../components/common/Badge.astro';
import Button from '../../components/common/Button.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

export const prerender = false;

let members: any[] = [];
let error = '';

const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime);

if (supabaseAdmin) {
  const { data, error: fetchError } = await supabaseAdmin
    .from('members')
    .select('*')
    .order('created_at', { ascending: false });

  if (fetchError) {
    error = fetchError.message;
  } else {
    members = data || [];
  }
}

const activeMembers = members.filter(m => m.status === 'active');
const inactiveMembers = members.filter(m => m.status === 'inactive');
---

<AdminLayout title="Members">
  <div class="mb-8 flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-bold text-white">Members</h1>
      <p class="text-white/70 mt-2">
        Manage community members
      </p>
    </div>
    <div class="flex items-center gap-4">
      <div class="text-sm text-white/60">
        {activeMembers.length} active / {inactiveMembers.length} inactive
      </div>
      <button
        id="add-member-btn"
        class="px-4 py-2 bg-ft-red text-white text-sm font-medium rounded-lg hover:bg-ft-red-dark transition-colors"
      >
        + Add Member
      </button>
    </div>
  </div>

  {error && (
    <div class="mb-6 p-4 backdrop-blur-xl bg-red-50/80 border border-red-200/50 rounded-xl text-red-700 text-sm">
      {error}
    </div>
  )}

  <!-- Add Member Modal -->
  <div id="add-member-modal" class="hidden fixed inset-0 bg-black/30 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="backdrop-blur-2xl bg-white/90 rounded-2xl shadow-2xl shadow-black/20 border border-white/50 max-w-lg w-full p-6">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl font-bold text-ft-black">Add New Member</h2>
        <button id="close-modal-btn" class="text-gray-400 hover:text-gray-600 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="add-member-form" class="space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="new-name" class="block text-sm font-medium text-ft-black mb-1">Name *</label>
            <input type="text" id="new-name" name="name" required
              class="w-full px-3 py-2 bg-white/60 backdrop-blur border border-white/40 rounded-xl focus:ring-2 focus:ring-ft-red focus:border-ft-red text-sm shadow-sm" />
          </div>
          <div>
            <label for="new-email" class="block text-sm font-medium text-ft-black mb-1">Email *</label>
            <input type="email" id="new-email" name="email" required
              class="w-full px-3 py-2 bg-white/60 backdrop-blur border border-white/40 rounded-xl focus:ring-2 focus:ring-ft-red focus:border-ft-red text-sm shadow-sm" />
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="new-company" class="block text-sm font-medium text-ft-black mb-1">Company</label>
            <input type="text" id="new-company" name="company"
              class="w-full px-3 py-2 bg-white/60 backdrop-blur border border-white/40 rounded-xl focus:ring-2 focus:ring-ft-red focus:border-ft-red text-sm shadow-sm" />
          </div>
          <div>
            <label for="new-role" class="block text-sm font-medium text-ft-black mb-1">Role/Title</label>
            <input type="text" id="new-role" name="role"
              class="w-full px-3 py-2 bg-white/60 backdrop-blur border border-white/40 rounded-xl focus:ring-2 focus:ring-ft-red focus:border-ft-red text-sm shadow-sm" />
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="new-linkedin" class="block text-sm font-medium text-ft-black mb-1">LinkedIn Username</label>
            <input type="text" id="new-linkedin" name="linkedin"
              class="w-full px-3 py-2 bg-white/60 backdrop-blur border border-white/40 rounded-xl focus:ring-2 focus:ring-ft-red focus:border-ft-red text-sm shadow-sm"
              placeholder="username" />
          </div>
          <div>
            <label for="new-member-role" class="block text-sm font-medium text-ft-black mb-1">Member Role</label>
            <select id="new-member-role" name="member_role"
              class="w-full px-3 py-2 bg-white/60 backdrop-blur border border-white/40 rounded-xl focus:ring-2 focus:ring-ft-red focus:border-ft-red text-sm shadow-sm">
              <option value="member">Member</option>
              <option value="admin">Admin</option>
            </select>
          </div>
        </div>
        <p id="add-form-message" class="text-sm hidden"></p>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="cancel-modal-btn"
            class="px-4 py-2 text-sm font-medium text-gray-600 hover:bg-white/60 rounded-xl transition-colors">
            Cancel
          </button>
          <button type="submit"
            class="px-4 py-2 bg-ft-red text-white text-sm font-medium rounded-xl hover:bg-[#9D000A] shadow-lg shadow-ft-red/25 transition-colors">
            Add Member
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Search/Filter -->
  <Card variant="glass" class="mb-6">
    <div class="flex flex-col sm:flex-row gap-4">
      <input
        type="text"
        placeholder="Search by name, email, or company..."
        class="flex-1 px-4 py-3 bg-white/60 backdrop-blur-xl border border-white/40 rounded-xl focus:ring-2 focus:ring-ft-red focus:border-ft-red shadow-sm"
        id="search-input"
      />
      <select
        class="px-4 py-3 bg-white/60 backdrop-blur-xl border border-white/40 rounded-xl focus:ring-2 focus:ring-ft-red focus:border-ft-red shadow-sm"
        id="status-filter"
      >
        <option value="">All Statuses</option>
        <option value="active">Active</option>
        <option value="inactive">Inactive</option>
      </select>
    </div>
  </Card>

  <!-- Members Table -->
  <Card variant="glass" padding="none">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-white/40 border-b border-white/40">
          <tr>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Member</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500 hidden md:table-cell">Company</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500 hidden lg:table-cell">Joined</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500 hidden lg:table-cell">Last Seen</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Status</th>
            <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Role</th>
            <th class="text-right px-6 py-3 text-sm font-medium text-gray-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/40" id="members-table">
          {members.length === 0 && !error && (
            <tr>
              <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                No members yet. Click "Add Member" to add your first member.
              </td>
            </tr>
          )}
          {members.map((member) => (
            <tr class="hover:bg-white/40 transition-colors member-row"
              data-id={member.id}
              data-name={member.name?.toLowerCase()}
              data-email={member.email?.toLowerCase()}
              data-company={member.company?.toLowerCase() || ''}
              data-status={member.status}>
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 bg-gradient-to-br from-slate-100 to-slate-200 rounded-xl flex items-center justify-center text-gray-600 font-medium shadow-inner">
                    {member.name ? member.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2) : '?'}
                  </div>
                  <div>
                    <div class="font-medium text-ft-black">{member.name}</div>
                    <div class="text-sm text-gray-500">{member.email}</div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 hidden md:table-cell">
                <div class="text-sm text-gray-700">{member.role || '-'}</div>
                <div class="text-sm text-gray-500">{member.company || '-'}</div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500 hidden lg:table-cell">
                {new Date(member.created_at).toLocaleDateString()}
              </td>
              <td class="px-6 py-4 text-sm text-gray-500 hidden lg:table-cell last-seen-cell" data-date={member.last_seen_at || ''}>
                {member.last_seen_at ? 'Loading...' : 'Never'}
              </td>
              <td class="px-6 py-4">
                <Badge variant={member.status === 'active' ? 'success' : 'default'}>
                  {member.status.charAt(0).toUpperCase() + member.status.slice(1)}
                </Badge>
              </td>
              <td class="px-6 py-4">
                <Badge variant={member.member_role === 'admin' ? 'info' : 'default'}>
                  {member.member_role.charAt(0).toUpperCase() + member.member_role.slice(1)}
                </Badge>
              </td>
              <td class="px-6 py-4 text-right">
                <div class="flex justify-end gap-3">
                  {member.member_role === 'admin' ? (
                    <button
                      class="text-sm text-orange-500 hover:text-orange-700 transition-colors remove-admin-btn"
                      data-id={member.id}
                    >
                      Remove Admin
                    </button>
                  ) : (
                    <button
                      class="text-sm text-blue-500 hover:text-blue-700 transition-colors make-admin-btn"
                      data-id={member.id}
                    >
                      Make Admin
                    </button>
                  )}
                  {member.status === 'active' ? (
                    <button
                      class="text-sm text-red-500 hover:text-red-700 transition-colors deactivate-btn"
                      data-id={member.id}
                    >
                      Deactivate
                    </button>
                  ) : (
                    <button
                      class="text-sm text-green-500 hover:text-green-700 transition-colors activate-btn"
                      data-id={member.id}
                    >
                      Activate
                    </button>
                  )}
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Card>
</AdminLayout>

<script>
  // Format relative time for last seen cells
  function formatRelativeTime(dateStr: string): string {
    if (!dateStr) return 'Never';
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return `${diffMins}m ago`;
    if (diffHours < 24) return `${diffHours}h ago`;
    if (diffDays < 7) return `${diffDays}d ago`;
    return date.toLocaleDateString();
  }

  // Update all last seen cells
  document.querySelectorAll('.last-seen-cell').forEach(cell => {
    const el = cell as HTMLElement;
    const dateStr = el.dataset.date;
    el.textContent = dateStr ? formatRelativeTime(dateStr) : 'Never';
  });

  // Search and filter
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;
  const rows = document.querySelectorAll('.member-row');

  function filterMembers() {
    const search = searchInput.value.toLowerCase();
    const status = statusFilter.value;

    rows.forEach(row => {
      const el = row as HTMLElement;
      const name = el.dataset.name || '';
      const email = el.dataset.email || '';
      const company = el.dataset.company || '';
      const rowStatus = el.dataset.status || '';

      const matchesSearch = !search ||
        name.includes(search) ||
        email.includes(search) ||
        company.includes(search);

      const matchesStatus = !status || rowStatus === status;

      el.style.display = matchesSearch && matchesStatus ? '' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterMembers);
  statusFilter?.addEventListener('change', filterMembers);

  // Add Member Modal
  const modal = document.getElementById('add-member-modal')!;
  const addBtn = document.getElementById('add-member-btn')!;
  const closeBtn = document.getElementById('close-modal-btn')!;
  const cancelBtn = document.getElementById('cancel-modal-btn')!;
  const addForm = document.getElementById('add-member-form') as HTMLFormElement;
  const addMessage = document.getElementById('add-form-message')!;

  function openModal() {
    modal.classList.remove('hidden');
  }

  function closeModal() {
    modal.classList.add('hidden');
    addForm.reset();
    addMessage.classList.add('hidden');
  }

  addBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  cancelBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  addForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(addForm);

    try {
      const response = await fetch('/api/admin/members', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: formData.get('name'),
          email: formData.get('email'),
          company: formData.get('company'),
          role: formData.get('role'),
          linkedin: formData.get('linkedin'),
          member_role: formData.get('member_role'),
        }),
      });

      const data = await response.json();

      if (response.ok) {
        // Reload page to show new member
        window.location.reload();
      } else {
        addMessage.textContent = data.error || 'Failed to add member.';
        addMessage.className = 'text-sm text-red-600';
        addMessage.classList.remove('hidden');
      }
    } catch (err) {
      addMessage.textContent = 'Something went wrong. Please try again.';
      addMessage.className = 'text-sm text-red-600';
      addMessage.classList.remove('hidden');
    }
  });

  // Activate/Deactivate buttons
  async function updateMemberStatus(id: string, status: string) {
    if (!confirm(`Are you sure you want to ${status === 'active' ? 'activate' : 'deactivate'} this member?`)) {
      return;
    }

    try {
      const response = await fetch('/api/admin/members', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, status }),
      });

      if (response.ok) {
        window.location.reload();
      } else {
        const data = await response.json();
        alert(data.error || 'Failed to update member.');
      }
    } catch {
      alert('Something went wrong.');
    }
  }

  document.querySelectorAll('.activate-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      updateMemberStatus(id, 'active');
    });
  });

  document.querySelectorAll('.deactivate-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      updateMemberStatus(id, 'inactive');
    });
  });

  // Make Admin / Remove Admin buttons
  async function updateMemberRole(id: string, member_role: string) {
    const action = member_role === 'admin' ? 'make this member an admin' : 'remove admin privileges from this member';
    if (!confirm(`Are you sure you want to ${action}?`)) {
      return;
    }

    try {
      const response = await fetch('/api/admin/members', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, member_role }),
      });

      if (response.ok) {
        window.location.reload();
      } else {
        const data = await response.json();
        alert(data.error || 'Failed to update member role.');
      }
    } catch {
      alert('Something went wrong.');
    }
  }

  document.querySelectorAll('.make-admin-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      updateMemberRole(id, 'admin');
    });
  });

  document.querySelectorAll('.remove-admin-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      updateMemberRole(id, 'member');
    });
  });
</script>
