---
import PublicLayout from '../../layouts/PublicLayout.astro';
import Container from '../../components/common/Container.astro';
import Section from '../../components/common/Section.astro';
import Card from '../../components/common/Card.astro';
import Button from '../../components/common/Button.astro';
---

<PublicLayout title="CEO Handbook" description="The comprehensive guide for French founders navigating the US market.">
  <Section background="black" padding="lg">
    <Container>
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold mb-6">CEO Handbook</h1>
        <p class="text-xl text-gray-300">
          The comprehensive guide for French founders navigating the US market.
        </p>
      </div>
    </Container>
  </Section>

  <Section background="white" padding="lg">
    <Container size="md">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Left: Description -->
        <div>
          <h2 class="text-2xl font-bold text-ft-black mb-4">What's Inside</h2>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start gap-3">
              <span class="text-ft-red mt-1">✓</span>
              <span>Visa options and immigration strategies</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-ft-red mt-1">✓</span>
              <span>US business entity setup and legal considerations</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-ft-red mt-1">✓</span>
              <span>Fundraising in the US vs. France</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-ft-red mt-1">✓</span>
              <span>Building and managing a US team</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-ft-red mt-1">✓</span>
              <span>Cultural differences and communication styles</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-ft-red mt-1">✓</span>
              <span>Boston tech ecosystem overview</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-ft-red mt-1">✓</span>
              <span>Interviews with successful French founders</span>
            </li>
          </ul>
        </div>

        <!-- Right: Download Form -->
        <Card>
          <h3 class="text-xl font-semibold text-ft-black mb-4">Get Your Free Copy</h3>
          <p class="text-gray-600 text-sm mb-6">
            Enter your email to receive the CEO Handbook PDF.
          </p>

          <form id="handbook-form" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-ft-black mb-1">
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ft-red focus:border-ft-red"
                placeholder="you@company.com"
              />
            </div>

            <div>
              <label for="name" class="block text-sm font-medium text-ft-black mb-1">
                Full Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ft-red focus:border-ft-red"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-ft-black mb-1">
                Company (Optional)
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ft-red focus:border-ft-red"
                placeholder="Your company"
              />
            </div>

            <Button type="submit" variant="primary" class="w-full">
              Download Handbook
            </Button>

            <p id="form-message" class="text-sm text-center hidden"></p>
          </form>
        </Card>
      </div>
    </Container>
  </Section>
</PublicLayout>

<script>
  const form = document.getElementById('handbook-form') as HTMLFormElement;
  const message = document.getElementById('form-message') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      const response = await fetch('/api/ceo-handbook', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: formData.get('email'),
          name: formData.get('name'),
          company: formData.get('company'),
        }),
      });

      const data = await response.json();

      if (response.ok) {
        message.textContent = 'Check your email for the download link!';
        message.className = 'text-sm text-center text-green-600';
        form.reset();
      } else {
        message.textContent = data.error || 'Something went wrong.';
        message.className = 'text-sm text-center text-red-600';
      }
      message.classList.remove('hidden');
    } catch (error) {
      message.textContent = 'Something went wrong. Please try again.';
      message.className = 'text-sm text-center text-red-600';
      message.classList.remove('hidden');
    }
  });
</script>
