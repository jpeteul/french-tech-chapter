---
import PublicLayout from '../../layouts/PublicLayout.astro';
import Container from '../../components/common/Container.astro';
import Section from '../../components/common/Section.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;

let resource: any = null;

const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime);

if (supabaseAdmin && slug) {
  const { data } = await supabaseAdmin
    .from('resources')
    .select('*')
    .eq('slug', slug)
    .eq('is_published', true)
    .single();

  resource = data;
}

if (!resource) {
  return Astro.redirect('/resources');
}

// Simple markdown-like rendering for content
function renderContent(content: string) {
  if (!content) return '';

  return content
    // Headers
    .replace(/^### (.+)$/gm, '<h3 class="text-xl font-semibold text-ft-navy mt-6 mb-3">$1</h3>')
    .replace(/^## (.+)$/gm, '<h2 class="text-2xl font-bold text-ft-navy mt-8 mb-4">$1</h2>')
    .replace(/^# (.+)$/gm, '<h1 class="text-3xl font-bold text-ft-navy mt-8 mb-4">$1</h1>')
    // Bold and italic
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    // Links
    .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" class="text-ft-red hover:underline">$1</a>')
    // Bullet lists
    .replace(/^- (.+)$/gm, '<li class="ml-4">$1</li>')
    // Line breaks and paragraphs
    .split('\n\n')
    .map(para => para.trim())
    .filter(para => para.length > 0)
    .map(para => {
      if (para.startsWith('<h') || para.startsWith('<ul') || para.startsWith('<ol') || para.startsWith('<li')) {
        return para;
      }
      return `<p class="mb-4 leading-relaxed">${para.replace(/\n/g, '<br>')}</p>`;
    })
    .join('\n');
}

const isFileResource = resource.type === 'file';
const isArticle = resource.type === 'article' || resource.type === 'guide';
const isPublicFile = isFileResource && !resource.is_gated && resource.file_url;

const getResourceIcon = (type: string) => {
  switch (type) {
    case 'file': return '📄';
    case 'guide': return '📘';
    case 'article': return '📝';
    case 'link': return '🔗';
    case 'member_page': return '👥';
    default: return '📄';
  }
};
---

<PublicLayout title={resource.title} description={resource.description || ''}>
  <!-- Hero Section -->
  <section class="relative text-white overflow-hidden min-h-[350px] flex items-center">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-ft-navy via-ft-blue to-ft-navy"></div>

    <!-- Decorative gradient blobs -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-to-br from-ft-red/20 to-transparent rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-to-tr from-ft-blue/40 to-transparent rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

    <Container class="relative py-16 sm:py-24">
      <div class="max-w-3xl">
        <a href="/resources" class="inline-flex items-center gap-2 text-white/70 hover:text-white mb-6 transition-colors group">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Resources
        </a>

        <div class="flex items-center gap-4 mb-4">
          <span class="text-5xl drop-shadow-lg">{resource.icon || getResourceIcon(resource.type)}</span>
          <div class="flex flex-wrap gap-2">
            {resource.is_gated && (
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-amber-500/20 backdrop-blur-sm text-amber-200 rounded-full text-sm font-medium border border-amber-500/30">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Email Required
              </span>
            )}
            {resource.is_members_only && (
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-blue-500/20 backdrop-blur-sm text-blue-200 rounded-full text-sm font-medium border border-blue-500/30">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                Members Only
              </span>
            )}
          </div>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 drop-shadow-lg">{resource.title}</h1>
        {resource.description && (
          <p class="text-xl text-gray-200 drop-shadow-md">{resource.description}</p>
        )}
      </div>
    </Container>
  </section>

  <!-- Content Section -->
  <Section background="navy-gradient" padding="lg">
    <Container>
      <div class="max-w-3xl mx-auto">
        {isFileResource && resource.is_gated ? (
          <!-- Gated file download form -->
          <div class="backdrop-blur-xl bg-white/95 rounded-3xl p-8 md:p-10 border border-white/50 shadow-2xl shadow-black/20">
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h2 class="text-2xl font-bold text-ft-navy mb-4">What's Inside</h2>
                {resource.content ? (
                  <div class="prose prose-sm text-gray-600">
                    <Fragment set:html={renderContent(resource.content)} />
                  </div>
                ) : (
                  <p class="text-gray-600">Download this resource to learn more about establishing your business in the US market.</p>
                )}
              </div>

              <div class="bg-gradient-to-br from-gray-50 to-white rounded-2xl p-6 border border-gray-100">
                <h3 class="text-xl font-semibold text-ft-navy mb-4">Get Your Free Copy</h3>
                <p class="text-gray-600 text-sm mb-6">
                  Enter your email to receive the download link.
                </p>

                <form id="download-form" class="space-y-4">
                  <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                      Full Name *
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-ft-red/20 focus:border-ft-red text-gray-900 transition-all"
                      placeholder="Your name"
                    />
                  </div>

                  <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                      Email Address *
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-ft-red/20 focus:border-ft-red text-gray-900 transition-all"
                      placeholder="you@company.com"
                    />
                  </div>

                  <button
                    type="submit"
                    class="w-full px-6 py-3 bg-gradient-to-r from-ft-red to-ft-red/90 text-white font-semibold rounded-xl hover:from-ft-red/90 hover:to-ft-red transition-all duration-300 shadow-lg shadow-ft-red/25 hover:shadow-xl hover:shadow-ft-red/30 hover:-translate-y-0.5"
                  >
                    Download Resource
                  </button>

                  <p id="form-message" class="text-sm text-center hidden"></p>
                </form>
              </div>
            </div>
          </div>
        ) : isPublicFile ? (
          <!-- Public file with email collection -->
          <div class="backdrop-blur-xl bg-white/95 rounded-3xl p-8 md:p-10 border border-white/50 shadow-2xl shadow-black/20">
            <div class="grid md:grid-cols-2 gap-8 items-center">
              <div class="text-center md:text-left">
                <div class="text-6xl mb-4">{resource.icon || getResourceIcon(resource.type)}</div>
                <h2 class="text-2xl font-bold text-ft-navy mb-4">{resource.title}</h2>
                {resource.content ? (
                  <div class="prose prose-sm text-gray-600">
                    <Fragment set:html={renderContent(resource.content)} />
                  </div>
                ) : (
                  <p class="text-gray-600">{resource.description}</p>
                )}
              </div>

              <div>
                <!-- Email collection form -->
                <div id="email-gate" class="bg-gradient-to-br from-gray-50 to-white rounded-2xl p-6 border border-gray-100">
                  <h3 class="text-xl font-semibold text-ft-navy mb-4">Get Your Free Copy</h3>
                  <p class="text-gray-600 text-sm mb-6">
                    Enter your details to download instantly.
                  </p>

                  <form id="public-download-form" class="space-y-4">
                    <div>
                      <label for="public-name" class="block text-sm font-medium text-gray-700 mb-1">
                        Full Name *
                      </label>
                      <input
                        type="text"
                        id="public-name"
                        name="name"
                        required
                        class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-ft-red/20 focus:border-ft-red text-gray-900 transition-all"
                        placeholder="Your name"
                      />
                    </div>

                    <div>
                      <label for="public-email" class="block text-sm font-medium text-gray-700 mb-1">
                        Email Address *
                      </label>
                      <input
                        type="email"
                        id="public-email"
                        name="email"
                        required
                        class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-ft-red/20 focus:border-ft-red text-gray-900 transition-all"
                        placeholder="you@company.com"
                      />
                    </div>

                    <button
                      type="submit"
                      class="w-full px-6 py-3 bg-gradient-to-r from-ft-red to-ft-red/90 text-white font-semibold rounded-xl hover:from-ft-red/90 hover:to-ft-red transition-all duration-300 shadow-lg shadow-ft-red/25 hover:shadow-xl hover:shadow-ft-red/30 hover:-translate-y-0.5 flex items-center justify-center gap-2"
                    >
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                      </svg>
                      Download Now
                    </button>

                    <p id="public-form-message" class="text-sm text-center hidden"></p>
                  </form>
                </div>

                <!-- Download complete message (hidden initially) -->
                <div id="download-complete" class="hidden bg-gradient-to-br from-green-50 to-white rounded-2xl p-6 border border-green-100 text-center">
                  <div class="text-5xl mb-4">✅</div>
                  <h3 class="text-xl font-semibold text-green-800 mb-2">Download Started!</h3>
                  <p class="text-green-700 text-sm mb-4">Your download should begin automatically.</p>
                  <a
                    id="manual-download-link"
                    href={resource.file_url}
                    download
                    class="inline-flex items-center gap-2 text-ft-red hover:underline font-medium"
                  >
                    Click here if it doesn't start
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ) : isArticle && resource.content ? (
          <!-- Article content -->
          <div class="backdrop-blur-xl bg-white/95 rounded-3xl p-8 md:p-12 border border-white/50 shadow-2xl shadow-black/20">
            <article class="prose prose-lg max-w-none text-gray-700">
              <Fragment set:html={renderContent(resource.content)} />
            </article>
          </div>
        ) : (
          <!-- Simple resource with link -->
          <div class="backdrop-blur-xl bg-white/95 rounded-3xl p-8 md:p-12 border border-white/50 shadow-2xl shadow-black/20 text-center">
            <div class="text-7xl mb-6">{resource.icon || getResourceIcon(resource.type)}</div>
            <h2 class="text-2xl font-bold text-ft-navy mb-4">{resource.title}</h2>
            <p class="text-gray-600 mb-8">{resource.description}</p>
            {resource.link_url && (
              <a
                href={resource.link_url}
                class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-ft-red to-ft-red/90 text-white font-semibold rounded-xl hover:from-ft-red/90 hover:to-ft-red transition-all duration-300 shadow-lg shadow-ft-red/25 hover:shadow-xl hover:shadow-ft-red/30 hover:-translate-y-0.5"
              >
                {resource.type === 'member_page' ? 'Access Resource' : 'Visit Resource'}
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
          </div>
        )}

        <div class="mt-8 text-center">
          <a
            href="/resources"
            class="inline-flex items-center gap-2 px-6 py-3 backdrop-blur-xl bg-white/10 text-white rounded-xl hover:bg-white/20 transition-all duration-300 border border-white/20 group"
          >
            <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to All Resources
          </a>
        </div>
      </div>
    </Container>
  </Section>
</PublicLayout>

<script define:vars={{ resourceSlug: slug, fileUrl: resource.file_url }}>
  // Gated resource form (sends email with download link)
  const gatedForm = document.getElementById('download-form');
  const gatedMessage = document.getElementById('form-message');

  gatedForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(gatedForm);

    const submitBtn = gatedForm.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.textContent = 'Sending...';
      submitBtn.disabled = true;
    }

    try {
      const response = await fetch('/api/resource-download', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: formData.get('email'),
          name: formData.get('name'),
          resource: resourceSlug,
        }),
      });

      const data = await response.json();

      if (response.ok) {
        gatedMessage.textContent = 'Check your email for the download link!';
        gatedMessage.className = 'text-sm text-center text-green-600 font-medium';
        gatedForm.reset();
      } else {
        gatedMessage.textContent = data.error || 'Something went wrong.';
        gatedMessage.className = 'text-sm text-center text-red-600 font-medium';
      }
      gatedMessage.classList.remove('hidden');
    } catch (error) {
      gatedMessage.textContent = 'Something went wrong. Please try again.';
      gatedMessage.className = 'text-sm text-center text-red-600 font-medium';
      gatedMessage.classList.remove('hidden');
    } finally {
      if (submitBtn) {
        submitBtn.textContent = 'Download Resource';
        submitBtn.disabled = false;
      }
    }
  });

  // Public file form (collects email, then downloads immediately)
  const publicForm = document.getElementById('public-download-form');
  const publicMessage = document.getElementById('public-form-message');
  const emailGate = document.getElementById('email-gate');
  const downloadComplete = document.getElementById('download-complete');

  publicForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(publicForm);

    const submitBtn = publicForm.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Processing...';
      submitBtn.disabled = true;
    }

    try {
      // Store email (fire and forget - don't block download)
      fetch('/api/resource-download', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: formData.get('email'),
          name: formData.get('name'),
          resource: resourceSlug,
          skipEmail: true,
        }),
      });

      // Trigger download immediately
      const link = document.createElement('a');
      link.href = fileUrl;
      link.download = '';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);

      // Show success state
      emailGate?.classList.add('hidden');
      downloadComplete?.classList.remove('hidden');

    } catch (error) {
      publicMessage.textContent = 'Something went wrong. Please try again.';
      publicMessage.className = 'text-sm text-center text-red-600 font-medium';
      publicMessage.classList.remove('hidden');

      if (submitBtn) {
        submitBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg> Download Now';
        submitBtn.disabled = false;
      }
    }
  });
</script>
