---
import MembersLayout from '../../../layouts/MembersLayout.astro';
import { STAGE_LABELS, SECTOR_LABELS, GEO_LABELS } from '../../../lib/supabase';

export const prerender = false;

const stages = Object.entries(STAGE_LABELS);
const sectors = Object.entries(SECTOR_LABELS);
const geos = Object.entries(GEO_LABELS);
---

<MembersLayout title="Add Investor">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <a href="/members/investors" class="text-white/70 hover:text-white text-sm flex items-center gap-1 mb-4">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Directory
      </a>
      <h1 class="text-3xl font-bold text-white mb-2">Add an Investor</h1>
      <p class="text-white/80">
        Share an investor you know personally with the community.
      </p>
    </div>

    <!-- Duplicate Check Banner (hidden by default) -->
    <div id="duplicate-banner" class="hidden bg-amber-500/20 border border-amber-400/30 rounded-xl p-4 mb-6">
      <p class="text-white font-medium mb-2">This investor may already exist</p>
      <p class="text-white/80 text-sm mb-3" id="duplicate-message"></p>
      <div class="flex gap-3">
        <button
          type="button"
          id="add-as-contact-btn"
          class="px-4 py-2 bg-amber-500 text-white rounded-lg hover:bg-amber-600 transition-colors text-sm"
        >
          Add yourself as a contact
        </button>
        <button
          type="button"
          id="create-new-btn"
          class="px-4 py-2 bg-white/10 text-white border border-white/20 rounded-lg hover:bg-white/20 transition-colors text-sm"
        >
          Create new anyway
        </button>
      </div>
    </div>

    <form id="add-investor-form" class="bg-white/10 backdrop-blur-sm rounded-2xl border border-white/20 p-6 space-y-6">
      <!-- Basic Info -->
      <div class="space-y-4">
        <h2 class="text-lg font-semibold text-white">Investor Information</h2>

        <div>
          <label for="name" class="block text-sm font-medium text-white/90 mb-1">
            Investor Name <span class="text-red-400">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="off"
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-red-500 focus:border-transparent"
            placeholder="e.g., John Smith"
          />
          <div id="name-suggestions" class="hidden mt-2 bg-white rounded-xl shadow-lg overflow-hidden"></div>
        </div>

        <div>
          <label for="firm" class="block text-sm font-medium text-white/90 mb-1">
            Firm / Fund Name
          </label>
          <input
            type="text"
            id="firm"
            name="firm"
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-red-500 focus:border-transparent"
            placeholder="e.g., Acme Ventures"
          />
        </div>

        <div>
          <label for="website" class="block text-sm font-medium text-white/90 mb-1">
            Website
          </label>
          <input
            type="url"
            id="website"
            name="website"
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-red-500 focus:border-transparent"
            placeholder="https://acmeventures.com"
          />
        </div>
      </div>

      <!-- Focus Areas -->
      <div class="space-y-4">
        <h2 class="text-lg font-semibold text-white">Investment Focus</h2>

        <div>
          <label class="block text-sm font-medium text-white/90 mb-2">Stage Focus</label>
          <div class="flex flex-wrap gap-2">
            {stages.map(([value, label]) => (
              <label class="cursor-pointer">
                <input type="checkbox" name="stage_focus" value={value} class="sr-only peer" />
                <span class="inline-block px-3 py-1.5 text-sm rounded-full border border-white/30 text-white/80 peer-checked:bg-purple-500 peer-checked:border-purple-500 peer-checked:text-white hover:border-white/50 transition-colors">
                  {label}
                </span>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-white/90 mb-2">Sector Focus</label>
          <div class="flex flex-wrap gap-2">
            {sectors.map(([value, label]) => (
              <label class="cursor-pointer">
                <input type="checkbox" name="sector_focus" value={value} class="sr-only peer" />
                <span class="inline-block px-3 py-1.5 text-sm rounded-full border border-white/30 text-white/80 peer-checked:bg-emerald-500 peer-checked:border-emerald-500 peer-checked:text-white hover:border-white/50 transition-colors">
                  {label}
                </span>
              </label>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-white/90 mb-2">Geographic Focus</label>
          <div class="flex flex-wrap gap-2">
            {geos.map(([value, label]) => (
              <label class="cursor-pointer">
                <input type="checkbox" name="geo_focus" value={value} class="sr-only peer" />
                <span class="inline-block px-3 py-1.5 text-sm rounded-full border border-white/30 text-white/80 peer-checked:bg-blue-500 peer-checked:border-blue-500 peer-checked:text-white hover:border-white/50 transition-colors">
                  {label}
                </span>
              </label>
            ))}
          </div>
        </div>
      </div>

      <!-- Check Size -->
      <div class="space-y-4">
        <h2 class="text-lg font-semibold text-white">Check Size (USD)</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="check_size_min" class="block text-sm font-medium text-white/90 mb-1">
              Minimum
            </label>
            <input
              type="number"
              id="check_size_min"
              name="check_size_min"
              min="0"
              step="10000"
              class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-red-500 focus:border-transparent"
              placeholder="e.g., 100000"
            />
          </div>
          <div>
            <label for="check_size_max" class="block text-sm font-medium text-white/90 mb-1">
              Maximum
            </label>
            <input
              type="number"
              id="check_size_max"
              name="check_size_max"
              min="0"
              step="10000"
              class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-red-500 focus:border-transparent"
              placeholder="e.g., 500000"
            />
          </div>
        </div>
      </div>

      <!-- Notes -->
      <div>
        <label for="notes" class="block text-sm font-medium text-white/90 mb-1">
          Public Notes
        </label>
        <textarea
          id="notes"
          name="notes"
          rows="3"
          class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none"
          placeholder="Any helpful context about this investor (visible to all members)..."
        ></textarea>
      </div>

      <!-- Private Relationship Note -->
      <div class="bg-white/5 rounded-xl p-4">
        <label for="relationship_note" class="block text-sm font-medium text-white/90 mb-1">
          Your Relationship (Private)
        </label>
        <textarea
          id="relationship_note"
          name="relationship_note"
          rows="2"
          class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-red-500 focus:border-transparent resize-none"
          placeholder="How do you know this investor? (Only visible to you)"
        ></textarea>
        <p class="text-white/50 text-xs mt-1">This note is private and only visible to you.</p>
      </div>

      <!-- Error Message -->
      <div id="error-message" class="hidden bg-red-500/20 border border-red-400/30 text-red-200 px-4 py-3 rounded-xl text-sm"></div>

      <!-- Submit -->
      <div class="flex gap-3">
        <a
          href="/members/investors"
          class="flex-1 px-4 py-3 bg-white/10 text-white border border-white/20 rounded-xl hover:bg-white/20 transition-colors text-center"
        >
          Cancel
        </a>
        <button
          type="submit"
          id="submit-btn"
          class="flex-1 px-4 py-3 bg-red-600 text-white rounded-xl hover:bg-red-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Add Investor
        </button>
      </div>
    </form>
  </div>
</MembersLayout>

<script>
  const form = document.getElementById('add-investor-form') as HTMLFormElement;
  const nameInput = document.getElementById('name') as HTMLInputElement;
  const firmInput = document.getElementById('firm') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorMessage = document.getElementById('error-message') as HTMLDivElement;
  const duplicateBanner = document.getElementById('duplicate-banner') as HTMLDivElement;
  const duplicateMessage = document.getElementById('duplicate-message') as HTMLParagraphElement;
  const addAsContactBtn = document.getElementById('add-as-contact-btn') as HTMLButtonElement;
  const createNewBtn = document.getElementById('create-new-btn') as HTMLButtonElement;

  let existingInvestorId: string | null = null;
  let forceCreate = false;

  // Handle duplicate found
  function showDuplicate(investor: { id: string; name: string; firm: string }) {
    existingInvestorId = investor.id;
    duplicateMessage.textContent = `"${investor.name}"${investor.firm ? ` at ${investor.firm}` : ''} is already in the directory.`;
    duplicateBanner.classList.remove('hidden');
  }

  addAsContactBtn?.addEventListener('click', async () => {
    if (!existingInvestorId) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Adding...';

    try {
      const relationshipNote = (document.getElementById('relationship_note') as HTMLTextAreaElement).value;

      const res = await fetch('/api/investors', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          existing_investor_id: existingInvestorId,
          relationship_note: relationshipNote,
        }),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Failed to add contact');
      }

      window.location.href = '/members/investors?added=contact';
    } catch (err: any) {
      errorMessage.textContent = err.message;
      errorMessage.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Add Investor';
    }
  });

  createNewBtn?.addEventListener('click', () => {
    forceCreate = true;
    duplicateBanner.classList.add('hidden');
    existingInvestorId = null;
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMessage.classList.add('hidden');

    const formData = new FormData(form);
    const name = formData.get('name') as string;
    const firm = formData.get('firm') as string;

    if (!name.trim()) {
      errorMessage.textContent = 'Investor name is required';
      errorMessage.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Adding...';

    try {
      const body = {
        name,
        firm,
        website: formData.get('website'),
        stage_focus: formData.getAll('stage_focus'),
        sector_focus: formData.getAll('sector_focus'),
        geo_focus: formData.getAll('geo_focus'),
        check_size_min: formData.get('check_size_min') ? Number(formData.get('check_size_min')) : null,
        check_size_max: formData.get('check_size_max') ? Number(formData.get('check_size_max')) : null,
        notes: formData.get('notes'),
        relationship_note: formData.get('relationship_note'),
      };

      const res = await fetch('/api/investors', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await res.json();

      if (res.status === 409 && data.error === 'duplicate' && !forceCreate) {
        showDuplicate(data.existing);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Add Investor';
        return;
      }

      if (!res.ok) {
        throw new Error(data.error || 'Failed to add investor');
      }

      window.location.href = '/members/investors?added=investor';
    } catch (err: any) {
      errorMessage.textContent = err.message;
      errorMessage.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Add Investor';
    }
  });
</script>
