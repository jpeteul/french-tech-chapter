---
import MembersLayout from '../../../layouts/MembersLayout.astro';
import Card from '../../../components/common/Card.astro';
import { getMember } from '../../../lib/auth';
import { getSupabaseAdmin, STAGE_LABELS, SECTOR_LABELS } from '../../../lib/supabase';

export const prerender = false;

const member = await getMember(Astro.cookies, Astro.locals.runtime, Astro.request);
const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime);

let myInvestors: any[] = [];
let pendingRequests: any[] = [];

if (supabaseAdmin && member) {
  // Fetch investors where current member is a contact
  const { data: contacts } = await supabaseAdmin
    .from('investor_contacts')
    .select(`
      id,
      relationship_note,
      added_at,
      investor:investor_id (
        id,
        name,
        firm,
        stage_focus,
        sector_focus
      )
    `)
    .eq('member_id', member.id)
    .order('added_at', { ascending: false });

  myInvestors = contacts || [];

  // Fetch pending intro requests received by this member
  const { data: requests } = await supabaseAdmin
    .from('intro_requests')
    .select(`
      id,
      message,
      status,
      created_at,
      investor:investor_id (
        id,
        name,
        firm
      ),
      requester:requester_id (
        id,
        name,
        company,
        role
      )
    `)
    .eq('contact_id', member.id)
    .eq('status', 'pending')
    .order('created_at', { ascending: false });

  pendingRequests = requests || [];
}
---

<MembersLayout title="My Investors">
  <div class="mb-8">
    <a href="/members/investors" class="text-white/70 hover:text-white text-sm flex items-center gap-1 mb-4">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Directory
    </a>
    <h1 class="text-3xl font-bold text-white mb-2">My Investors</h1>
    <p class="text-white/80">
      Investors you've added yourself as a contact for.
    </p>
  </div>

  <!-- Pending Intro Requests -->
  {pendingRequests.length > 0 && (
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
        <span class="w-6 h-6 bg-amber-500 rounded-full flex items-center justify-center text-sm">{pendingRequests.length}</span>
        Pending Introduction Requests
      </h2>
      <div class="space-y-4">
        {pendingRequests.map((request: any) => (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl border border-white/20 p-5">
            <div class="flex items-start justify-between mb-3">
              <div>
                <p class="text-white font-medium">
                  {request.requester.name}
                  <span class="text-white/60 font-normal">
                    {request.requester.company ? ` from ${request.requester.company}` : ''}
                  </span>
                </p>
                <p class="text-white/70 text-sm">
                  wants an intro to <strong class="text-white">{request.investor.name}</strong>
                  {request.investor.firm ? ` (${request.investor.firm})` : ''}
                </p>
              </div>
              <span class="px-2 py-1 bg-amber-500/20 text-amber-300 text-xs rounded-full">
                Pending
              </span>
            </div>

            <div class="bg-white/5 rounded-lg p-3 mb-4">
              <p class="text-white/80 text-sm italic">"{request.message}"</p>
            </div>

            <div class="flex gap-3">
              <button
                type="button"
                class="accept-btn flex-1 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors text-sm"
                data-request-id={request.id}
              >
                Accept
              </button>
              <button
                type="button"
                class="decline-btn flex-1 px-4 py-2 bg-white/10 text-white border border-white/20 rounded-lg hover:bg-white/20 transition-colors text-sm"
                data-request-id={request.id}
              >
                Decline
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- My Investor Contacts -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-white">
        Your Contacts ({myInvestors.length})
      </h2>
      <a
        href="/members/investors/add"
        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors text-sm flex items-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Investor
      </a>
    </div>

    {myInvestors.length === 0 ? (
      <div class="bg-white/10 backdrop-blur-sm rounded-xl border border-white/20 p-8 text-center">
        <p class="text-white/70 mb-4">You haven't added yourself as a contact for any investors yet.</p>
        <a
          href="/members/investors/add"
          class="inline-block px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors"
        >
          Add your first investor
        </a>
      </div>
    ) : (
      <div class="space-y-4">
        {myInvestors.map((contact: any) => (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl border border-white/20 p-5">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-white">{contact.investor.name}</h3>
                {contact.investor.firm && (
                  <p class="text-white/70">{contact.investor.firm}</p>
                )}

                {/* Tags */}
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {contact.investor.stage_focus?.slice(0, 3).map((stage: string) => (
                    <span class="px-2 py-0.5 bg-purple-500/30 text-purple-200 text-xs rounded-full">
                      {STAGE_LABELS[stage as keyof typeof STAGE_LABELS] || stage}
                    </span>
                  ))}
                  {contact.investor.sector_focus?.slice(0, 2).map((sector: string) => (
                    <span class="px-2 py-0.5 bg-emerald-500/30 text-emerald-200 text-xs rounded-full">
                      {SECTOR_LABELS[sector as keyof typeof SECTOR_LABELS] || sector}
                    </span>
                  ))}
                </div>

                {/* Private Note */}
                {contact.relationship_note && (
                  <div class="mt-3 bg-white/5 rounded-lg p-3">
                    <p class="text-xs text-white/50 mb-1">Your private note:</p>
                    <p class="text-white/80 text-sm">{contact.relationship_note}</p>
                  </div>
                )}

                <p class="text-white/50 text-xs mt-2">
                  Added {new Date(contact.added_at).toLocaleDateString()}
                </p>
              </div>

              <div class="flex gap-2 ml-4">
                <button
                  type="button"
                  class="edit-note-btn p-2 text-white/60 hover:text-white hover:bg-white/10 rounded-lg transition-colors"
                  data-contact-id={contact.id}
                  data-current-note={contact.relationship_note || ''}
                  title="Edit note"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                </button>
                <button
                  type="button"
                  class="remove-btn p-2 text-white/60 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition-colors"
                  data-contact-id={contact.id}
                  data-investor-name={contact.investor.name}
                  title="Remove yourself"
                >
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</MembersLayout>

<script>
  // Handle intro request accept/decline
  document.querySelectorAll('.accept-btn, .decline-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const requestId = target.dataset.requestId;
      const status = target.classList.contains('accept-btn') ? 'accepted' : 'declined';

      if (!confirm(`Are you sure you want to ${status === 'accepted' ? 'accept' : 'decline'} this introduction request?`)) {
        return;
      }

      target.disabled = true;
      target.textContent = status === 'accepted' ? 'Accepting...' : 'Declining...';

      try {
        const res = await fetch('/api/investors/intro-requests', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ request_id: requestId, status }),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to update request');
        }

        window.location.reload();
      } catch (err: any) {
        alert(err.message);
        target.disabled = false;
        target.textContent = status === 'accepted' ? 'Accept' : 'Decline';
      }
    });
  });

  // Handle remove contact
  document.querySelectorAll('.remove-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const contactId = target.dataset.contactId;
      const investorName = target.dataset.investorName;

      if (!confirm(`Remove yourself as a contact for ${investorName}?`)) {
        return;
      }

      try {
        const res = await fetch(`/api/investors/contacts/${contactId}`, {
          method: 'DELETE',
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to remove contact');
        }

        window.location.reload();
      } catch (err: any) {
        alert(err.message);
      }
    });
  });

  // Handle edit note
  document.querySelectorAll('.edit-note-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const contactId = target.dataset.contactId;
      const currentNote = target.dataset.currentNote || '';

      const newNote = prompt('Edit your private relationship note:', currentNote);

      if (newNote === null) return; // Cancelled

      try {
        const res = await fetch(`/api/investors/contacts/${contactId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ relationship_note: newNote }),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to update note');
        }

        window.location.reload();
      } catch (err: any) {
        alert(err.message);
      }
    });
  });
</script>
