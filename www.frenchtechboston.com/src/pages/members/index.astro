---
import MembersLayout from '../../layouts/MembersLayout.astro';
import Card from '../../components/common/Card.astro';
import Button from '../../components/common/Button.astro';
import Badge from '../../components/common/Badge.astro';
import { getMember } from '../../lib/auth';
import { createServerClient, getSupabaseAdmin } from '../../lib/supabase';

export const prerender = false;

const member = await getMember(Astro.cookies, Astro.locals.runtime, Astro.request);
const supabase = createServerClient(Astro.cookies, Astro.request);
const supabaseAdmin = getSupabaseAdmin(Astro.locals.runtime);

let pendingRequestsCount = 0;
let connectionsCount = 0;
let whatsappUrl = '';
let showWhatsappPrompt = false;

// Fetch WhatsApp URL from site settings
if (supabaseAdmin) {
  const { data: setting } = await supabaseAdmin
    .from('site_settings')
    .select('value')
    .eq('key', 'whatsapp_community_url')
    .single();

  whatsappUrl = setting?.value || '';
}

if (supabase && member) {
  // Check if should show WhatsApp prompt (not dismissed yet)
  showWhatsappPrompt = whatsappUrl && !member.whatsapp_prompt_dismissed;
  // Count pending incoming requests
  const { count: pendingCount } = await supabase
    .from('connection_requests')
    .select('*', { count: 'exact', head: true })
    .eq('receiver_id', member.id)
    .eq('status', 'pending');

  pendingRequestsCount = pendingCount || 0;

  // Count accepted connections
  const { count: sentAccepted } = await supabase
    .from('connection_requests')
    .select('*', { count: 'exact', head: true })
    .eq('requester_id', member.id)
    .eq('status', 'accepted');

  const { count: receivedAccepted } = await supabase
    .from('connection_requests')
    .select('*', { count: 'exact', head: true })
    .eq('receiver_id', member.id)
    .eq('status', 'accepted');

  connectionsCount = (sentAccepted || 0) + (receivedAccepted || 0);
}
---

<MembersLayout title="Dashboard">
  <!-- WhatsApp First-Login Prompt -->
  {showWhatsappPrompt && (
    <div id="whatsapp-prompt" class="mb-6 bg-gradient-to-r from-green-500 to-emerald-600 rounded-2xl p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <div>
          <p class="text-white font-semibold">Welcome! Join our WhatsApp Community to stay in the loop.</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 bg-white text-green-600 rounded-xl hover:bg-white/90 transition-colors font-medium text-sm"
        >
          Join on WhatsApp
        </a>
        <button
          id="dismiss-whatsapp"
          class="text-white/80 hover:text-white text-sm underline"
        >
          Maybe later
        </button>
      </div>
    </div>
  )}

  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Welcome Message Panel -->
    <div class="lg:w-2/5 lg:sticky lg:top-8 lg:self-start">
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20">
        <h1 class="text-2xl font-bold text-white mb-4">
          Welcome to the Community{member?.name ? `, ${member.name.split(' ')[0]}` : ''}
        </h1>

        <div class="text-white/90 space-y-4 text-sm leading-relaxed">
          <p>
            Membership in La French Tech Boston is free, and we intend to keep it that way.
            This community exists for one reason: to help each other do something incredibly hard. Building a successful business.
            Everything we do revolves around that mission.
          </p>

          <p class="font-medium text-white">
            That said, a community only works if everyone contributes. Here's how you can give back:
          </p>

          <ul class="space-y-3">
            <li class="flex gap-3">
              <span class="text-lg">📍</span>
              <div>
                <span class="font-semibold text-white">Show up.</span>
                <span class="text-white/80"> Come to our events. That's where the magic happens: the introductions, the advice, the "I had the exact same problem" moments.</span>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-lg">📣</span>
              <div>
                <span class="font-semibold text-white">Spread the word.</span>
                <span class="text-white/80"> If you know a French tech entrepreneur or executive in the Boston area who should be here, tell them about us. The stronger the network, the more we can do for each other.</span>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-lg">🚪</span>
              <div>
                <span class="font-semibold text-white">Open your doors.</span>
                <span class="text-white/80"> If you have office space that could host an event, offer it up. Venues are one of our biggest constraints.</span>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-lg">💝</span>
              <div>
                <span class="font-semibold text-white">Support financially.</span>
                <span class="text-white/80"> Sponsor an event or make a donation. It helps us keep membership free and run better programming.</span>
              </div>
            </li>
          </ul>

          <div class="mt-6 p-4 bg-white/10 rounded-xl border border-white/10">
            <p class="text-white/90">
              <span class="font-semibold text-white">A note on exclusive events.</span>
              Some events have limited seats. If you RSVP and can't make it, just let us know so we can give your spot to someone else.
              If you no-show without notice, you'll be deprioritized for future exclusive events. It's not a penalty, it's just fair to the members on the waitlist.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Dashboard Cards -->
    <div class="lg:w-3/5">
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-white">Your Dashboard</h2>
        <p class="text-white/70 text-sm mt-1">Quick access to member resources</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <!-- Profile Card -->
        <Card variant="glass" hover>
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 bg-gradient-to-br from-ft-red to-rose-600 rounded-2xl flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-ft-red/25">
              {member?.name ? member.name.split(' ').map(n => n[0]).join('').slice(0, 2) : '?'}
            </div>
            <div class="flex-1">
              <h3 class="font-semibold text-ft-black">{member?.name || 'Member'}</h3>
              <p class="text-sm text-gray-500">{member?.company || 'Company not set'}</p>
            </div>
          </div>
          <div class="mt-4">
            <Button href="/members/profile" variant="outline" size="sm" class="w-full">
              Edit Profile
            </Button>
          </div>
        </Card>

        <!-- Connections Card -->
        <Card variant="glass" hover>
          <div class="flex items-start justify-between">
            <div class="w-12 h-12 bg-gradient-to-br from-amber-400 to-orange-500 rounded-xl flex items-center justify-center text-2xl shadow-lg shadow-amber-500/25">🤝</div>
            {pendingRequestsCount > 0 && (
              <Badge variant="warning">{pendingRequestsCount} pending</Badge>
            )}
          </div>
          <h3 class="font-semibold text-ft-black mt-4 mb-2">My Connections</h3>
          <p class="text-sm text-gray-600 mb-4">
            {connectionsCount} connection{connectionsCount !== 1 ? 's' : ''} • Manage requests
          </p>
          <Button href="/members/connections" variant={pendingRequestsCount > 0 ? 'primary' : 'outline'} size="sm">
            {pendingRequestsCount > 0 ? 'View Requests' : 'View Connections'}
          </Button>
        </Card>

        <!-- WhatsApp Community Card -->
        {whatsappUrl && (
          <Card variant="glass" hover class="sm:col-span-2 bg-gradient-to-br from-green-500/10 to-emerald-500/5 border-green-500/20">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-green-500 rounded-xl flex items-center justify-center shadow-lg shadow-green-500/25">
                <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="font-semibold text-ft-black mb-1">Join our WhatsApp Community</h3>
                <p class="text-sm text-gray-600 mb-3">
                  This is where the daily conversation happens: job leads, advice, introductions, and event updates in real time.
                </p>
                <div class="flex flex-col sm:flex-row sm:items-center gap-2">
                  <a
                    href={whatsappUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-green-500 text-white rounded-xl hover:bg-green-600 transition-colors font-medium text-sm"
                  >
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                    Join on WhatsApp
                  </a>
                  <span class="text-xs text-gray-500">You'll be asked to request to join. An admin will approve you shortly.</span>
                </div>
              </div>
            </div>
          </Card>
        )}

        <!-- Directory Card -->
        <Card variant="glass" hover>
          <div class="w-12 h-12 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-xl flex items-center justify-center text-2xl shadow-lg shadow-blue-500/25">👥</div>
          <h3 class="font-semibold text-ft-black mt-4 mb-2">Member Directory</h3>
          <p class="text-sm text-gray-600 mb-4">
            Browse and request introductions
          </p>
          <Button href="/members/directory" variant="outline" size="sm">
            View Directory
          </Button>
        </Card>

        <!-- Events Card -->
        <Card variant="glass" hover>
          <div class="w-12 h-12 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-xl flex items-center justify-center text-2xl shadow-lg shadow-emerald-500/25">📅</div>
          <h3 class="font-semibold text-ft-black mt-4 mb-2">Upcoming Events</h3>
          <p class="text-sm text-gray-600 mb-4">
            RSVP to member-exclusive events
          </p>
          <Button href="/events" variant="outline" size="sm">
            View Events
          </Button>
        </Card>

        <!-- Investor Directory Card -->
        <Card variant="glass" hover>
          <div class="w-12 h-12 bg-gradient-to-br from-green-400 to-emerald-600 rounded-xl flex items-center justify-center text-2xl shadow-lg shadow-green-500/25">💰</div>
          <h3 class="font-semibold text-ft-black mt-4 mb-2">Investor Directory</h3>
          <p class="text-sm text-gray-600 mb-4">
            Find investors through the community
          </p>
          <Button href="/members/investors" variant="outline" size="sm">
            Browse Investors
          </Button>
        </Card>

        <!-- Resources Card -->
        <Card variant="glass" hover>
          <div class="w-12 h-12 bg-gradient-to-br from-purple-400 to-violet-500 rounded-xl flex items-center justify-center text-2xl shadow-lg shadow-purple-500/25">📚</div>
          <h3 class="font-semibold text-ft-black mt-4 mb-2">Resources</h3>
          <p class="text-sm text-gray-600 mb-4">
            Access member-only guides and materials
          </p>
          <Button href="/resources" variant="outline" size="sm">
            Browse Resources
          </Button>
        </Card>

        <!-- Community Card -->
        <Card variant="glass" hover>
          <div class="w-12 h-12 bg-gradient-to-br from-sky-400 to-blue-500 rounded-xl flex items-center justify-center text-2xl shadow-lg shadow-sky-500/25">💬</div>
          <h3 class="font-semibold text-ft-black mt-4 mb-2">Community</h3>
          <p class="text-sm text-gray-600 mb-4">
            Join our LinkedIn group for discussions
          </p>
          <Button href="https://linkedin.com/company/la-french-tech-boston" variant="outline" size="sm">
            Join LinkedIn
          </Button>
        </Card>

      <!-- Help Card -->
      <Card variant="glass" hover>
        <div class="w-12 h-12 bg-gradient-to-br from-gray-400 to-slate-500 rounded-xl flex items-center justify-center text-2xl shadow-lg shadow-gray-500/25">❓</div>
        <h3 class="font-semibold text-ft-black mt-4 mb-2">Need Help?</h3>
        <p class="text-sm text-gray-600 mb-4">
          Contact us for any questions
        </p>
        <Button href="/contact" variant="outline" size="sm">
          Contact Us
        </Button>
      </Card>
      </div>
    </div>
  </div>
</MembersLayout>

<script>
  const dismissBtn = document.getElementById('dismiss-whatsapp');
  const promptDiv = document.getElementById('whatsapp-prompt');

  dismissBtn?.addEventListener('click', async () => {
    try {
      const response = await fetch('/api/members/dismiss-whatsapp', {
        method: 'POST',
      });

      if (response.ok) {
        promptDiv?.remove();
      }
    } catch (error) {
      // Just hide it anyway
      promptDiv?.remove();
    }
  });
</script>
