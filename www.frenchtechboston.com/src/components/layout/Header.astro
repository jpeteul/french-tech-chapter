---
import { NAV_LINKS, SITE_TITLE } from '../../lib/constants';
import Button from '../common/Button.astro';
import MobileMenu from './MobileMenu';

interface Props {
  user?: { email?: string } | null;
  member?: { name?: string; member_role?: string } | null;
}

const { user, member } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="bg-ft-white border-b border-gray-100 sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img src="/images/logo/ft-boston-logo.png" alt={SITE_TITLE} class="h-12 w-auto" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-6">
        {NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-ft-red',
              currentPath === link.href ? 'text-ft-red' : 'text-ft-black',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Auth / CTA -->
      <div class="hidden md:flex items-center gap-4">
        {user ? (
          <>
            <a href="/members" class="text-sm font-medium text-ft-black hover:text-ft-red">
              Dashboard
            </a>
            {member?.member_role === 'admin' && (
              <a href="/admin" class="text-sm font-medium text-ft-black hover:text-ft-red">
                Admin
              </a>
            )}
            <form action="/api/auth/logout" method="POST">
              <button type="submit" class="text-sm font-medium text-gray-500 hover:text-ft-red">
                Log out
              </button>
            </form>
          </>
        ) : (
          <>
            <a href="/auth/login" class="text-sm font-medium text-ft-black hover:text-ft-red">
              Member Login
            </a>
            <Button href="/apply" variant="primary" size="sm">
              Join Us
            </Button>
          </>
        )}
      </div>

      <!-- Mobile Menu -->
      <MobileMenu
        navLinks={NAV_LINKS}
        currentPath={currentPath}
        user={user}
        member={member}
        client:load
      />
    </div>
  </nav>
</header>
