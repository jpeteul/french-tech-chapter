---
interface Props {
  class?: string;
  background?: 'white' | 'gray' | 'black' | 'navy' | 'navy-gradient';
  padding?: 'sm' | 'md' | 'lg';
}

const {
  class: className = '',
  background = 'white',
  padding = 'lg',
} = Astro.props;

const backgrounds = {
  white: 'bg-ft-white',
  gray: 'bg-ft-gray',
  black: 'bg-ft-navy text-white',
  navy: 'bg-ft-navy text-white',
  'navy-gradient': 'bg-gradient-to-br from-ft-navy via-ft-blue to-ft-navy text-white',
};

const paddings = {
  sm: 'py-8 sm:py-12',
  md: 'py-12 sm:py-16',
  lg: 'py-16 sm:py-24',
};

const isGradient = background === 'navy-gradient';
---

{isGradient ? (
  <section class:list={[backgrounds[background], paddings[padding], 'relative overflow-hidden', className]}>
    <!-- Decorative gradient blobs -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-gradient-to-br from-ft-red/20 to-transparent rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-gradient-to-tr from-ft-blue/40 to-transparent rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>
    <div class="relative">
      <slot />
    </div>
  </section>
) : (
  <section class:list={[backgrounds[background], paddings[padding], className]}>
    <slot />
  </section>
)}
