---
interface Props {
  name: string;
  title?: string;
  company?: string;
  linkedin?: string;
  image?: string;
  boardRole?: string;
}

const { name, title, company, linkedin, image, boardRole } = Astro.props;

const initials = name
  .split(' ')
  .map((n) => n[0])
  .join('')
  .slice(0, 2);
---

<div class="backdrop-blur-xl bg-white/90 rounded-2xl p-6 border border-white/50 shadow-xl shadow-black/20 hover:bg-white hover:shadow-2xl hover:shadow-black/25 hover:-translate-y-1 transition-all duration-300">
  <div class="flex flex-col items-center text-center">
    <!-- Avatar -->
    {image ? (
      <img
        src={image}
        alt={name}
        class="w-24 h-24 rounded-2xl object-cover mb-4 shadow-lg"
      />
    ) : (
      <div class="w-24 h-24 rounded-2xl bg-gradient-to-br from-ft-red to-rose-600 flex items-center justify-center mb-4 shadow-lg shadow-ft-red/25">
        <span class="text-2xl font-bold text-white">{initials}</span>
      </div>
    )}

    <!-- Name -->
    <h3 class="text-lg font-semibold text-ft-black">{name}</h3>

    <!-- Board Role -->
    {boardRole && (
      <p class="text-sm font-semibold text-ft-red">{boardRole}</p>
    )}

    <!-- Title & Company -->
    {(title || company) && (
      <p class="text-sm text-gray-600 mt-1">
        {title}
        {title && company && ' at '}
        {company && <span class="font-medium">{company}</span>}
      </p>
    )}

    <!-- LinkedIn -->
    {linkedin && (
      <a
        href={`https://linkedin.com/in/${linkedin}`}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex items-center gap-2 px-4 py-2 bg-ft-navy/10 hover:bg-ft-red text-ft-navy hover:text-white text-sm font-medium rounded-xl transition-all duration-300"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        Connect
      </a>
    )}
  </div>
</div>
